# ── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Database ─────────────────────────────────────────────────────────────────
# Replace with your MongoDB Atlas connection string — never commit the real URI
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/elnadjah?retryWrites=true&w=majority

# ── JWT Secrets ───────────────────────────────────────────────────────────────
# Generate each with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# All must be 64+ characters in production
JWT_STAFF_SECRET=change_me_use_64_plus_random_chars
JWT_STUDENT_SECRET=change_me_use_64_plus_random_chars
JWT_REFRESH_STAFF_SECRET=change_me_use_64_plus_random_chars
JWT_REFRESH_STUDENT_SECRET=change_me_use_64_plus_random_chars

# ── CORS Origins ─────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173
STUDENT_APP_URL=http://localhost:5174
